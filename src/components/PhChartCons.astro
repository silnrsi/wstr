			<td class='phon'><a href='/scrlang/phonemes/stp-pal-vl' title='voiceless palatal plosive'>c</a></td>
			<td class='phon'><a href='/scrlang/phonemes/stp-vel-vl' title='voiceless velar plosive'>k</a></td>
			<td class='phon'><a href='/scrlang/phonemes/stp-bil-vl' title='voiceless uvular plosive'>q</a></td>
			<td class='phon'>&nbsp;</td>
			<td class='phon'>&nbsp;</td>
			<td class='phon'><a href='/scrlang/phonemes/stp-glo-vl' title='voiceless linguolabial plosive'>ʔ</a></td>

		</tr>
	</tbody>

</table>
</div>
