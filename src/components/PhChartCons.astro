			<th class='hdrlabel'><img src="/src/content/docs/scrlang/phonemes/images/velar.png" alt="Velar" height="95px" width="18px" /></th>
			<th class='hdrlabel'><img src="/src/content/docs/scrlang/phonemes/images/uvular.png" alt="Uvular" height="95px" width="18px" /></th>
			<th class='hdrlabel'><img src="/src/content/docs/scrlang/phonemes/images/pharyngeal.png" alt="Pharyngeal" height="95px" width="18px" /></th>
			<th class='hdrlabel'><img src="/src/content/docs/scrlang/phonemes/images/epiglottal.png" alt="Epiglottal" height="95px" width="18px" /></th>
			<th class='hdrlabel'><img src="/src/content/docs/scrlang/phonemes/images/glottal.png" alt="Glottal" height="95px" width="18px" /></th>
		</tr>
	</thead>

	<tbody>
		<tr>
			<td class='ptype'>Nasal</td><td/>
			<td class='phon'><a href='/scrlang/phonemes/nas-bil' title='bilabial nasal'>m</a></td>
			<td class='phon'><a href='/scrlang/phonemes/nas-lbd' title='labiodental nasal'>ɱ</a></td>
			<td class='phon'><a href='/scrlang/phonemes/nas-llb' title='linguolabial nasal'>n̼</a></td>
			<td class='phon'><a href='/scrlang/phonemes/nas-den' title='dental nasal'>n̪</a></td>
			<td class='phon'><a href='/scrlang/phonemes/nas-alv' title='alveolar nasal'>n</a></td>
			<td class='phon'><a href='/scrlang/phonemes/nas-ret' title='retrflex nasal'>ɳ</a></td>
